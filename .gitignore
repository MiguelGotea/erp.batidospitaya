# ── Raíz: excluir todo excepto lo permitido ────────────────────────────────
/*
!/.gitignore
!/modulos/
!/.scripts/
!/README.md
!/.github/
!/core/
!/docs/
!/.agent/
# Las carpetas core, docs y .agent son trackeadas en GitHub
# pero excluidas del host vía --exclude en deploy-erp.yml

# ── Excluir TODAS las carpetas uploads/ en cualquier nivel ─────────────────
**/uploads/

# ══════════════════════════════════════════════════════════════════════════════
# EXCEPCIONES TEMPORALES — Carpetas de fotos que NO se llaman uploads/
# Estas carpetas almacenan archivos subidos por usuarios pero tienen nombres
# distintos a "uploads". Eliminar cada línea cuando se migre a uploads/ correcta.
# ══════════════════════════════════════════════════════════════════════════════
/modulos/supervision/auditorias_original/auditinternas/fotos_auditorias_caja_chica/
/modulos/supervision/auditorias_original/auditinternas/fotos_auditorias_caja_facturacion/
/modulos/supervision/auditorias_original/auditinternas/fotos_auditorias_inventario/
/modulos/supervision/auditorias_original/fotos/
/modulos/supervision/auditorias_original/fotoslimpieza/
/modulos/supervision/auditorias_original/fotospersonal/
/modulos/supervision/auditorias_original/fotosservicio/
# ══════════════════════════════════════════════════════════════════════════════