# Excluir TODO en la raíz EXCEPTO lo permitido
/*
!/.gitignore
!/modulos/
!/.scripts/
!/README.md
!/.github/
!/core/
!/docs/
!/.agent/
# Las 3 carpetas compartidas (core, docs, .agent) son trackeadas en GitHub
# pero excluidas del host vía --exclude en deploy-erp.yml

